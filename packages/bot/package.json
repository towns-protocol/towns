{
    "name": "@towns-protocol/bot",
    "version": "0.0.167",
    "packageManager": "yarn@3.8.0",
    "type": "module",
    "main": "dist/node.cjs",
    "scripts": {
        "build": "node ./esbuild.config.mjs",
        "run-build": "NODE_TLS_REJECT_UNAUTHORIZED=0 node ./dist/node_esbuild.cjs",
        "dev": "yarn build & yarn run-build",
        "cb": "yarn clean && yarn build",
        "clean": "rm -rf dist",
        "lint": "yarn eslint --format unix ./src  --max-warnings=0",
        "lint:fix": "yarn lint --fix",
        "test:ci": "yarn test:ci:multi:ne",
        "test:watch": "vitest --watch"
    },
    "dependencies": {
        "@bufbuild/protobuf": "^2.2.2",
        "@connectrpc/connect-web": "^2.0.0",
        "@hono/node-server": "^1.14.0",
        "@towns-protocol/dlog": "workspace:^",
        "@towns-protocol/encryption": "workspace:^",
        "@towns-protocol/proto": "workspace:^",
        "@towns-protocol/sdk": "workspace:^",
        "@towns-protocol/web3": "workspace:^",
        "ethers": "^5.7.2",
        "fake-indexeddb": "^4.0.1",
        "hono": "^4.7.6",
        "typed-emitter": "^2.1.0"
    },
    "devDependencies": {
        "@types/node": "^20.14.8",
        "@typescript-eslint/eslint-plugin": "^8.29.0",
        "@typescript-eslint/parser": "^8.29.0",
        "esbuild": "^0.21.5",
        "esbuild-plugin-pino": "^2.2.0",
        "eslint": "^8.57.0",
        "eslint-import-resolver-typescript": "^3.5.5",
        "eslint-plugin-import": "^2.27.5",
        "eslint-plugin-tsdoc": "^0.3.0",
        "typescript": "^5.8.2",
        "vitest": "3.0.5"
    },
    "files": [
        "/dist"
    ]
}
