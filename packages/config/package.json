{
    "name": "@towns-protocol/config",
    "version": "0.0.228",
    "description": "All-in-one config used by Towns Protocol projects.",
    "author": "tannerlinsley",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Towns-Protocol/towns-protocol.git",
        "directory": "packages/config"
    },
    "publishConfig": {
        "access": "public"
    },
    "type": "module",
    "exports": {
        "./eslint": {
            "import": {
                "types": "./dist/esm/eslint.d.ts",
                "default": "./dist/esm/eslint.js"
            }
        },
        "./vite": {
            "import": {
                "types": "./dist/esm/vite.d.ts",
                "default": "./dist/esm/vite.js"
            }
        },
        "./package.json": "./package.json"
    },
    "sideEffects": false,
    "files": [
        "dist",
        "src"
    ],
    "dependencies": {
        "vite-plugin-dts": "4.5.4",
        "vite-plugin-externalize-deps": "0.9.0",
        "vite-tsconfig-paths": "5.1.4"
    },
    "devDependencies": {
        "vite": "^6.3.5"
    }
}
