{
  "name": "@towns-protocol/subgraph",
  "private": true,
  "type": "module",
  "scripts": {
    "codegen": "yarn typings && ponder codegen",
    "db": "ponder db",
    "dev": "yarn typings && ponder dev",
    "dev:fork": "./scripts/setup-subgraph.sh",
    "dev:no-ui": "yarn typings && ponder dev --disable-ui",
    "find-paths": "tsx utils/findContractsPath.ts",
    "format": "prettier --write \"src/**/*.{ts,tsx}\" \"ponder.config.ts\" \"ponder.schema.ts\"",
    "lint": "oxlint src ponder.config.ts ponder.schema.ts --type-aware",
    "serve": "yarn typings && ponder serve",
    "start": "yarn typings && ponder start",
    "test:unit": "yarn typings && sh -c 'tsc --noEmit'",
    "transfer-ownership": "tsx interactions/transfer-ownership.ts",
    "typings": "turbo typings --filter @towns-protocol/contracts && turbo build --filter @towns-protocol/web3"
  },
  "dependencies": {
    "@towns-protocol/web3": "workspace:^",
    "hono": "^4.7.11",
    "ponder": "^0.13.14",
    "viem": "^2.29.3"
  },
  "devDependencies": {
    "@towns-protocol/contracts": "workspace:^",
    "@towns-protocol/generated": "workspace:^",
    "@towns-protocol/prettier-config": "workspace:^",
    "@types/node": "^20.14.8",
    "eslint-import-resolver-typescript": "^4.3.2",
    "eslint-plugin-prettier": "^5.2.6",
    "eslint-plugin-tsdoc": "^0.3.0",
    "oxlint": "^1.25.0",
    "oxlint-tsgolint": "^0.5.0",
    "prettier": "^3.5.3",
    "tsx": "^4.7.1",
    "turbo": "^2.5.4",
    "typescript": "~5.8.3"
  },
  "engines": {
    "node": ">=18.14"
  }
}
